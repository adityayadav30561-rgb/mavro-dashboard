{
  "name": "mavro-admin-backend",
  "version": "1.0.0",
  "description": "Mavro centralized multi-website SEO management backend",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seeder.js",
    "seed:spanbix": "node src/utils/seedSpanbix.js",
    "set:spanbix-author": "node src/utils/setSpanbixAuthor.js",
    "create:spanbix-blog": "node src/utils/createSpanbixBlog.js",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:client",
    "prod": "NODE_ENV=production node src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop mavro-api",
    "pm2:restart": "pm2 restart mavro-api",
    "pm2:logs": "pm2 logs mavro-api",
    "pm2:monit": "pm2 monit",
    "docker:build": "docker build -t mavro-admin .",
    "docker:run": "docker run -p 5000:5000 --env-file .env mavro-admin",
    "test:e2e": "playwright test",
    "test:e2e:spanbix": "playwright test --project=spanbix-chromium --project=spanbix-webkit --project=spanbix-mobile-chromium --project=spanbix-mobile-webkit",
    "test:e2e:admin": "playwright test --project=admin-chromium --project=admin-webkit",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/report",
    "test:e2e:trace": "playwright show-trace",
    "create:saisatwik-blog": "node src/utils/createSaisatwikBlog.js"
  },
  "keywords": [
    "seo",
    "admin",
    "multi-website",
    "blog",
    "lead-management",
    "multi-tenant"
  ],
  "author": "Mavro",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "googleapis": "^172.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "openai": "^6.37.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "nodemon": "^3.1.4"
  }
}
