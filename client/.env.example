# ═══════════════════════════════════════════════════════════════════════════
# Mavro Frontend — environment variable contract
# ───────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.production`) and fill in real values for
# whichever deploy target you're building for. Vite exposes only variables
# prefixed with VITE_ to client code; never put secrets here — anything that
# lands in the bundle is publicly visible.
# ═══════════════════════════════════════════════════════════════════════════

# ─── API base URL ─────────────────────────────────────────────────────────
# Resolved by src/lib/apiBase.js. Controls where axios + the analytics
# beacon send their requests.
#
#   Unset (local dev):       defaults to '' → relative `/api/...` paths,
#                            forwarded by the Vite proxy to localhost:5000
#   Unset (co-hosted prod):  defaults to '' → same-origin `/api/...`,
#                            handled by Express that serves the React build
#   Set (independent deploy, e.g. Spanbix on Vercel):
#     VITE_API_BASE_URL=https://api.spanbix.com
#                            → axios issues `https://api.spanbix.com/api/...`
#                            → analytics beacons hit the remote backend
#
# Do NOT include a trailing slash. `apiPath()` strips trailing slashes anyway,
# but keeping the var clean avoids surprises in logs.
VITE_API_BASE_URL=


# ─── Build target ─────────────────────────────────────────────────────────
# Selects which entry point + HTML shell Vite uses at build time. Drives the
# multi-property deploy story (Spanbix on spanbix.com, HRMS on hrms.mavro.com,
# Tickets on tickets.mavro.com, full Mavro Console on dashboard.mavro.com),
# all powered by the same Render backend.
#
#   full     (default)  — index.html + src/main.jsx + App.jsx
#                         Mavro Console with every public site under
#                         `/spanbix/*`, `/hrms/*`, `/tickets/*` + admin routes.
#   spanbix             — index.spanbix.html + src/entries/spanbix.jsx +
#                         SpanbixApp.jsx
#                         Standalone Spanbix bundle, routes at root.
#   hrms / tickets      — reserved for future standalone deployments.
#
# CLI usage:  cross-env VITE_BUILD_TARGET=spanbix vite build
# npm script: npm run build:spanbix  (also dev:spanbix, build:full, etc.)
# Vercel:     set in Project Settings → Environment Variables.
VITE_BUILD_TARGET=full
