# ===================================
# Mavro Admin Backend - Environment
# ===================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/mavro_admin

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Admin Seed (used by seeder script)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@mavro.com
ADMIN_PASSWORD=Admin@123456

# Spanbix Next.js on-demand ISR revalidation (Phase 5)
# Base URL of the spanbix-web Next.js app + shared secret (must match spanbix-web env).
# Leave unset to disable revalidation (silent no-op).
SPANBIX_WEB_URL=https://www.spanbix.com
REVALIDATE_SECRET=

# ===================================
# MBR Dashboard — GA4 + Search Console (Phase 10)
# ===================================
# Service-account key JSON from Google Cloud (IAM > Service Accounts > Keys).
# Paste the WHOLE file contents, raw JSON or base64-encoded (base64 recommended
# for Render's env UI). The same account must be added as:
#   - GA4:            Admin > Property access management > Viewer
#   - Search Console: Settings > Users and permissions > Full
GOOGLE_SERVICE_ACCOUNT_JSON=

# GA4 numeric property ID (Admin > Property settings — NOT the G-XXXX measurement id)
GA4_PROPERTY_ID=

# Search Console property, exactly as verified:
#   domain property: sc-domain:spanbix.com
#   URL-prefix:      https://www.spanbix.com/
GSC_SITE_URL=sc-domain:spanbix.com

# Multi-source MBR (optional). JSON array of GA4/GSC sources shown as tabs on /mbr
# and exported as separate sheets. The service account must have access to each.
# Falls back to a single "spanbix" source from GA4_PROPERTY_ID + GSC_SITE_URL above.
# Each source may use its own service account via credentialsEnv (name of another env var
# holding that account key, raw or base64) — needed when sources live in different GCP projects.
# MBR_SOURCES=[{"key":"spanbix","label":"Spanbix","ga4PropertyId":"541588648","gscSiteUrl":"https://www.spanbix.com/","websiteSlug":"spanbix"},{"key":"saisatwik","label":"SaiSatwik","ga4PropertyId":"368831716","gscSiteUrl":"https://saisatwik.com/","wordpressUrl":"https://saisatwik.com","credentialsEnv":"GOOGLE_SERVICE_ACCOUNT_JSON_SAISATWIK"}]
# GOOGLE_SERVICE_ACCOUNT_JSON_SAISATWIK=

# SaiSatwik WordPress blog publishing (npm run create:saisatwik-blog — local CLI only)
# Application Password from wp-admin > Users > Profile > Application Passwords.
SAISATWIK_WP_URL=https://saisatwik.com
SAISATWIK_WP_USER=
SAISATWIK_WP_APP_PASSWORD=
